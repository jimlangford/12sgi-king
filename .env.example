# Example environment file for Tailscale surface hosts
# Copy to .env (do NOT commit real secrets/credentials if they are sensitive).
# Format: comma-separated name=host:port pairs
# Example:
# SURFACES_LIST="surfaceA=100.101.102.103:8782,surfaceB=100.101.102.104:8782"

# Centralized list of surfaces for healthchecks and configs
SURFACES_LIST="surfaceA=TS_IP_OR_HOSTNAME_A:8782,surfaceB=TS_IP_OR_HOSTNAME_B:8782"

# Optional: public-safe paths you want to map on the homepage (comma-separated)
# Example: PATH_MAP="surfaceA=/surfaceA,surfaceB=/surfaceB"
PATH_MAP="surfaceA=/surfaceA,surfaceB=/surfaceB"

# ── govOS v2 auth service — OAuth (copy to .env.v2, keep gitignored) ──────────
# GitHub OAuth app (Settings → Developer settings → OAuth Apps → New OAuth App)
#   Homepage URL: https://12sgi.com
#   Authorization callback URL: https://auth.12sgi.com/api/v2/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth app (console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID)
#   Authorized redirect URI: https://auth.12sgi.com/api/v2/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public URL where this auth service is reachable (Cloudflare Tunnel endpoint).
AUTH_PUBLIC_URL=https://auth.12sgi.com

# Console URL to redirect back to after sign-in (token appended as #token=…).
OAUTH_REDIRECT_BASE=https://12sgi.com/king/

# Comma-separated lists of allowed GitHub logins and Google e-mails.
OWNER_GITHUB_LOGINS=jimlangford
OWNER_GOOGLE_EMAILS=

# Comma-separated list of console origins for CORS.
CORS_ORIGINS=https://jimlangford.github.io,https://12sgi.com

# Token signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SIGNING_SECRET=
