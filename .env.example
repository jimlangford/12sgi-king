# Example environment file for Tailscale surface hosts
# Copy to .env (do NOT commit real secrets/credentials if they are sensitive).
# Format: comma-separated name=host:port pairs
# Example:
# SURFACES_LIST="surfaceA=100.101.102.103:8782,surfaceB=100.101.102.104:8782"

# Centralized list of surfaces for healthchecks and configs
SURFACES_LIST="surfaceA=TS_IP_OR_HOSTNAME_A:8782,surfaceB=TS_IP_OR_HOSTNAME_B:8782"

# Optional: public-safe paths you want to map on the homepage (comma-separated)
# Example: PATH_MAP="surfaceA=/surfaceA,surfaceB=/surfaceB"
PATH_MAP="surfaceA=/surfaceA,surfaceB=/surfaceB"
