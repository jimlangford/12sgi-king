# .env.watchdog — Auto-compact and feature flags for 12sgi-king\n# Copy to .env and customize for your environment\n\n# ─── Neo4j Conversation Auto-Compact ──────────────────────────────────────────\nNEO4J_CONV_AUTO_COMPACT=true\nNEO4J_CONV_TTL_DAYS=30\nNEO4J_CONV_BATCH_SIZE=1000\nNEO4J_CONV_SCHEDULE_HOUR=2\nNEO4J_CONV_ARCHIVE_DIR=./data/archived-conversations\n\n# Retention by environment:\n# NEO4J_RETENTION_PRODUCTION=90  (90 days)\n# NEO4J_RETENTION_STAGING=30    (30 days)\n# NEO4J_RETENTION_DEV=7         (7 days)\nENVIRONMENT=production\n\n# ─── Watchdog Settings ────────────────────────────────────────────────────────\nWATCHDOG_POLL_MS=30000\nWATCHDOG_RESTART_DELAY_MS=5000\nWATCHDOG_UNHEALTHY_THRESHOLD_MS=8000\nWATCHDOG_MAX_RESTARTS=5\n\n# ─── Health Check Settings ────────────────────────────────────────────────────\nHEALTH_CHECK_TIMEOUT_MS=4000\nHEALTH_CHECK_RETRIES=12\nHEALTH_CHECK_RETRY_DELAY_MS=2000\nHEALTH_PERSISTENT_CHECK_MS=300000\n\n# ─── Feature Flags ───────────────────────────────────────────────────────────\nFEATURE_PERSISTENT_SESSION=true\nFEATURE_CONVERSATION_CACHE=true\nFEATURE_BACKGROUND_INDEXING=true\nFEATURE_HEALTH_DASHBOARD=true\nFEATURE_GRACEFUL_DEGRADATION=true\nFEATURE_REQUEST_COMPRESSION=true\nFEATURE_CORS_ENABLED=true\nFEATURE_RATE_LIMITING=true\nFEATURE_REQUEST_LOGGING=true\nFEATURE_PERFORMANCE_TRACING=true\n\n# ─── API Server Settings ─────────────────────────────────────────────────────\nKING_BRIDGE_HOST=127.0.0.1\nKING_BRIDGE_PORT=8109\nKING_BRIDGE_WORKERS=2\nKING_BRIDGE_LOG_LEVEL=info\n\nSTATIC_SERVER_HOST=127.0.0.1\nSTATIC_SERVER_PORT=8888\n\n# ─── Ollama (optional inference engine) ───────────────────────────────────────\nOLLAMA_HOST=http://localhost:11434\nOLLAMA_ENABLED=true\nOLLAMA_MODELS=llama2,mistral,neural-chat\nOLLAMA_TIMEOUT_MS=30000\n\n# ─── Logging ──────────────────────────────────────────────────────────────────\nLOG_FORMAT=json\nLOG_LEVEL=info\nLOG_FILE=./watchdog.log\nLOG_MAX_SIZE_BYTES=52428800\nLOG_MAX_FILES=5\nLOG_COLORIZE=true\n\n# ─── Docker Configuration ────────────────────────────────────────────────────\nDOCKER_COMPOSE_FILE=docker-compose.v2.yml\nDOCKER_NETWORK=12sgi-king_default\nDOCKER_TIMEOUT_MS=30000\n\n# ─── Neo4j Connection ───────────────────────────────────────────────────────\nNEO4J_URI=bolt://localhost:7687\nNEO4J_USER=neo4j\nNEO4J_PASSWORD=changeme\nNEO4J_TIMEOUT_MS=10000\n\n# ─── Project Metadata (reference) ─────────────────────────────────────────────\n# Tenants: 13 (9 films, 1 game, 2 music videos, 1 civic studio)\n# Characters: 25 named\n# Lipsync skills: 6\n# Render styles: 5\n# Civic divisions: 12\n