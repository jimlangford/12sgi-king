{
  "version": "2.2",
  "tenant": "media",
  "description": "Phase 2.2 media workflow inventory. Kandinsky5 handles storyboard images, keyframes, and owner-preferred animation; LTX is the primary image-to-video engine; RIFE interpolates approved takes (VRAM measured live, never assumed); Wan 1.3B engines exist only as disabled experimental entries. No Wan 14B model is ever registered.",
  "workflows": [
    {
      "workflow_id": "kandinsky5_local_image",
      "display_name": "Kandinsky 5 Local Image (Storyboard / Keyframe)",
      "engine": "kandinsky5_local",
      "capability": "image_generation",
      "enabled": true,
      "resolution": "768x512",
      "resolution_width": 768,
      "resolution_height": 512,
      "vram_required_mb": 6900,
      "execution_modes": ["cuda"],
      "default_mode": "cuda",
      "permitted_job_types": ["storyboard_frame", "character_reference"]
    },
    {
      "workflow_id": "kandinsky5_local_animation",
      "display_name": "Kandinsky 5 Local Animation (Owner-Preferred)",
      "engine": "kandinsky5_local",
      "capability": "kandinsky_animation",
      "enabled": true,
      "resolution": "768x512",
      "resolution_width": 768,
      "resolution_height": 512,
      "vram_required_mb": 7300,
      "execution_modes": ["cuda"],
      "default_mode": "cuda",
      "permitted_job_types": ["animation_shot"]
    },
    {
      "workflow_id": "ltx_image_to_video",
      "display_name": "LTX Image-to-Video (Primary Motion)",
      "engine": "ltx",
      "capability": "image_to_video",
      "enabled": true,
      "resolution": "768x512",
      "resolution_width": 768,
      "resolution_height": 512,
      "vram_required_mb": 7100,
      "execution_modes": ["cuda"],
      "default_mode": "cuda",
      "permitted_job_types": ["animation_shot"]
    },
    {
      "workflow_id": "wan_vace_1_3b_experimental",
      "display_name": "Wan VACE 1.3B (Experimental Fallback)",
      "engine": "wan_vace_1_3b",
      "capability": "image_to_video",
      "enabled": false,
      "experimental": true,
      "requires_benchmark": true,
      "resolution": "768x512",
      "resolution_width": 768,
      "resolution_height": 512,
      "vram_required_mb": 5200,
      "execution_modes": ["cuda"],
      "default_mode": "cuda",
      "permitted_job_types": ["animation_shot"]
    },
    {
      "workflow_id": "wan_t2v_1_3b_atmospheric",
      "display_name": "Wan T2V 1.3B (Atmospheric Inserts Only)",
      "engine": "wan_t2v_1_3b",
      "capability": "text_to_video",
      "enabled": false,
      "experimental": true,
      "requires_benchmark": true,
      "resolution": "768x512",
      "resolution_width": 768,
      "resolution_height": 512,
      "vram_required_mb": 5200,
      "execution_modes": ["cuda"],
      "default_mode": "cuda",
      "permitted_job_types": ["atmospheric_insert"],
      "prohibited_job_types": ["storyboard_frame", "character_reference", "animation_shot"]
    },
    {
      "workflow_id": "rife_local_interpolation",
      "display_name": "RIFE Local Interpolation",
      "engine": "rife_local",
      "capability": "interpolation",
      "enabled": true,
      "vram_required_mb": null,
      "requires_live_measurement": true,
      "execution_modes": ["cuda", "cpu"],
      "default_mode": "cuda",
      "permitted_job_types": ["interpolation_shot"]
    }
  ]
}
