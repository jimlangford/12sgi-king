{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "game_cinematic",
  "description": "Schema for a game cinematic record. Shots carry storyboard and camera references, and the sequencer_manifest retains those references verbatim for Unreal Sequencer export.",
  "type": "object",
  "properties": {
    "cinematic_id": {
      "type": "string",
      "description": "Cinematic record ID."
    },
    "game_id": {
      "type": "string",
      "description": "Owning game project."
    },
    "scene_id": {
      "type": "string",
      "description": "Studio scene this cinematic realizes."
    },
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "default": "cutscene"
    },
    "shots": {
      "type": "array",
      "description": "Ordered cinematic shots. Storyboard references survive storyboard archive/restore.",
      "items": {
        "type": "object",
        "properties": {
          "shot_id": {
            "type": "string"
          },
          "storyboard_id": {
            "type": "string",
            "description": "Studio storyboard reference; carried verbatim into the sequencer manifest."
          },
          "camera_spec": {
            "type": "object",
            "description": "Camera movement/framing spec for this shot."
          },
          "duration_seconds": {
            "type": "number",
            "minimum": 0.0
          },
          "dialogue_id": {
            "type": "string",
            "description": "Studio dialogue block ID spoken over this shot."
          },
          "sequencer_shot_id": {
            "type": "string",
            "description": "Shot ID inside the Unreal Sequencer asset."
          }
        },
        "required": ["shot_id"]
      }
    },
    "camera_rig": {
      "type": "object",
      "description": "Rig configuration shared across shots."
    },
    "audio_cue_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sequencer_manifest": {
      "type": "object",
      "description": "Unreal/Sequencer export manifest. Retains storyboard and camera references from the shots.",
      "properties": {
        "format": {
          "type": "string",
          "default": "sequencer_manifest"
        },
        "shot_count": {
          "type": "integer",
          "minimum": 0
        },
        "shots": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "cinematic_id": {
                "type": "string"
              },
              "shot_id": {
                "type": "string"
              },
              "storyboard_id": {
                "type": "string"
              },
              "camera_spec": {
                "type": "object"
              },
              "duration_seconds": {
                "type": "number"
              },
              "dialogue_id": {
                "type": "string"
              },
              "sequencer_shot_id": {
                "type": "string"
              }
            }
          }
        },
        "storyboard_refs": {
          "type": "array",
          "description": "Unique storyboard IDs referenced by the manifest's shots.",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "archived": {
      "type": "boolean",
      "default": false
    },
    "created_at": {
      "type": "string"
    }
  },
  "required": ["game_id", "shots"],
  "example": {
    "cinematic_id": "STARFORGE-CIN-004",
    "game_id": "GAME-001",
    "scene_id": "HWTF-S01",
    "title": "Opening",
    "type": "cutscene",
    "shots": [
      {
        "shot_id": "CIN-SH001",
        "storyboard_id": "HWTF-S01-SH003-SB01",
        "camera_spec": {
          "movement": "slow_push_in"
        },
        "duration_seconds": 6.8,
        "dialogue_id": "HWTF-S01-D004",
        "sequencer_shot_id": "SEQ-SH001"
      }
    ],
    "camera_rig": {},
    "audio_cue_ids": [],
    "sequencer_manifest": {
      "format": "sequencer_manifest",
      "shot_count": 1,
      "shots": [
        {
          "cinematic_id": "STARFORGE-CIN-004",
          "shot_id": "CIN-SH001",
          "storyboard_id": "HWTF-S01-SH003-SB01",
          "camera_spec": {
            "movement": "slow_push_in"
          },
          "duration_seconds": 6.8,
          "dialogue_id": "HWTF-S01-D004",
          "sequencer_shot_id": "SEQ-SH001"
        }
      ],
      "storyboard_refs": ["HWTF-S01-SH003-SB01"]
    },
    "archived": false,
    "created_at": "2026-07-22T00:00:00+00:00"
  }
}
