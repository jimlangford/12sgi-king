# .env example for the health service
# Do NOT commit real hostnames/ips. Use repository secrets or deployment env vars.

# SURFACES_LIST: comma-separated name=host:port pairs
# e.g. SURFACES_LIST="surfaceA=TS_IP_OR_HOSTNAME_A:8782,surfaceB=TS_IP_OR_HOSTNAME_B:8782"
SURFACES_LIST="surfaceA=TS_IP_OR_HOSTNAME_A:8782,surfaceB=TS_IP_OR_HOSTNAME_B:8782"

# Admin protection
# ADMIN_ALLOWED_IPS: comma-separated IPs or CIDRs allowed to access /admin/status (preferred)
ADMIN_ALLOWED_IPS=""
# Fallback basic auth (username/password)
ADMIN_BASIC_USER=""
ADMIN_BASIC_PASS=""

# Release metadata file path (written by deploy workflow)
RELEASE_FILE="/var/www/elementlotus/current/release.json"

# Service version
VERSION="0.1.0"
