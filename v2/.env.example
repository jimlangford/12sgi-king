# Environment template — copy this reference when documenting configuration.
# NEVER put real tokens or credentials here.
# Real tokens go in:
#   secrets/hf_token.txt
#   secrets/github_token.txt
#   secrets/ts_authkey.txt
# Those files are .gitignored and never committed.

APP_ENV=local
APP_PORT=8088

# Hugging Face model to pull on first run
HF_MODEL_ID=Qwen/Qwen2.5-Coder-7B-Instruct

# Ollama base URL (internal Docker service name)
LOCAL_LLM_URL=http://ollama:11434
